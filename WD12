        // Associative array of students and marks
        $students = [
            "John" => ["Math" => 85, "Science" => 90, "English" => 78],
            "Sarah" => ["Math" => 92, "Science" => 88, "English" => 95],
            "David" => ["Math" => 75, "Science" => 80, "English" => 70]
        ];

        echo "<table>";
        echo "<tr>
                <th>Student Name</th>
                <th>Math</th>
                <th>Science</th>
                <th>English</th>
              </tr>";

        foreach ($students as $name => $marks) {
            echo "<tr>
                    <td>$name</td>
                    <td>{$marks['Math']}</td>
                    <td>{$marks['Science']}</td>
                    <td>{$marks['English']}</td>
                  </tr>";
        }

        echo "</table>";
