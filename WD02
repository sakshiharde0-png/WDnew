<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Web Page with Gallery, Links & Timetable</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            text-align: center;
        }

        header {
            background-color: darkblue;
            color: white;
            padding: 20px;
        }

        .section {
            background: white;
            margin: 20px auto;
            padding: 20px;
            width: 90%;
            max-width: 1000px;
            border-radius: 10px;
            box-shadow: 0px 0px 10px gray;
        }

        /* Image Gallery */
        .gallery {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            gap: 15px;
        }

        .gallery img {
            width: 200px;
            height: 150px;
            object-fit: cover;
            border-radius: 8px;
            border: 2px solid #ccc;
        }

        /* Social Links */
        .social a {
            display: inline-block;
            margin: 10px;
            padding: 10px 15px;
            background-color: darkblue;
            color: white;
            text-decoration: none;
            border-radius: 5px;
        }

        .social a:hover {
            background-color: green;
        }

        /* Timetable */
        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid black;
            padding: 10px;
        }

        th {
            background-color: darkblue;
            color: white;
        }

        tr:nth-child(even) {
            background-color: #f2f2f2;
        }
    </style>
</head>
<body>

<header>
    <h1>Student Portal</h1>
</header>

<!-- Image Gallery Section -->
<div class="section">
    <h2>Image Gallery</h2>

    <div class="gallery">
        <img src="https://via.placeholder.com/200x150" alt="Image 1">
        <img src="https://via.placeholder.com/200x150" alt="Image 2">
        <img src="https://via.placeholder.com/200x150" alt="Image 3">
        <img src="https://via.placeholder.com/200x150" alt="Image 4">
    </div>
</div>

<!-- Social Media Links -->
<div class="section social">
    <h2>Follow Us</h2>

    <a href="https://www.facebook.com" target="_blank">Facebook</a>
    <a href="https://www.instagram.com" target="_blank">Instagram</a>
    <a href="https://www.twitter.com" target="_blank">Twitter</a>
    <a href="https://www.linkedin.com" target="_blank">LinkedIn</a>
</div>

<!-- Timetable Section -->
<div class="section">
    <h2>Class Timetable</h2>

    <table>
        <tr>
            <th>Day</th>
            <th>9-10 AM</th>
            <th>10-11 AM</th>
            <th>11-12 PM</th>
            <th>12-1 PM</th>
        </tr>

        <tr>
            <td>Monday</td>
            <td>Math</td>
            <td>Physics</td>
            <td>Chemistry</td>
            <td>Break</td>
        </tr>

        <tr>
            <td>Tuesday</td>
            <td>English</td>
            <td>Computer</td>
            <td>Math</td>
            <td>Break</td>
        </tr>

        <tr>
            <td>Wednesday</td>
            <td>Physics</td>
            <td>Chemistry</td>
            <td>English</td>
            <td>Break</td>
        </tr>

        <tr>
            <td>Thursday</td>
            <td>Computer</td>
            <td>Math</td>
            <td>Physics</td>
            <td>Break</td>
        </tr>

        <tr>
            <td>Friday</td>
            <td>English</td>
            <td>Chemistry</td>
            <td>Computer</td>
            <td>Break</td>
        </tr>
    </table>
</div>

</body>
</html>
