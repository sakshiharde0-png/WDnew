<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dynamic Background & Text Change</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            text-align: center;
            transition: 0.5s;
            padding-top: 80px;
        }

        .box {
            background: white;
            padding: 30px;
            width: 300px;
            margin: auto;
            border-radius: 10px;
            box-shadow: 0px 0px 10px gray;
        }

        button {
            padding: 10px 15px;
            margin: 10px;
            border: none;
            cursor: pointer;
            border-radius: 5px;
            font-size: 14px;
        }

        .red { background: red; color: white; }
        .blue { background: blue; color: white; }
        .green { background: green; color: white; }
    </style>
</head>
<body>

    <div class="box">
        <h2 id="text">Hello! Click a button</h2>

        <button class="red" onclick="changeStyle('red', 'Red Theme Activated!')">
            Red
        </button>

        <button class="blue" onclick="changeStyle('blue', 'Blue Theme Activated!')">
            Blue
        </button>

        <button class="green" onclick="changeStyle('green', 'Green Theme Activated!')">
            Green
        </button>
    </div>

    <script>
        function changeStyle(color, message) {
            // Change background color
            document.body.style.backgroundColor = color;

            // Change text dynamically
            document.getElementById("text").innerText = message;
        }

        // Extra DOM event example: mouse hover effect
        document.getElementById("text").addEventListener("mouseover", function () {
            this.style.color = "purple";
        });

        document.getElementById("text").addEventListener("mouseout", function () {
            this.style.color = "black";
        });
    </script>

</body>
</html>
